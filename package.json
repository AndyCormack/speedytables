{
  "name": "speedytables-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "bench": "pnpm --filter demo build && pnpm --filter bench bench",
    "bench:report": "pnpm --filter bench report"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-svelte": "^3.10.0",
    "prettier": "^3.6.0",
    "prettier-plugin-svelte": "^3.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0"
  }
}
